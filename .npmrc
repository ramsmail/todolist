public-hoist-pattern[]=babel-preset-expo

# apps/web pins React 18, packages/ui and apps/mobile pin React 19 for RN
# compatibility. pnpm's default hoist-pattern[]=* puts one arbitrary copy of
# react/@types/react into node_modules/.pnpm/node_modules, which deeply
# nested tools (e.g. Next.js's own .d.ts files) can resolve into via plain
# Node directory-walk, silently picking the wrong major version and breaking
# apps/web's typecheck. Exclude them so every package is forced to use its
# own correctly-scoped, directly-linked copy.
hoist-pattern[]=*
hoist-pattern[]=!react
hoist-pattern[]=!react-dom
hoist-pattern[]=!@types/react
hoist-pattern[]=!@types/react-dom
