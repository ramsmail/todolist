{
  "expo": {
    "name": "TodoList",
    "slug": "todolist",
    "version": "1.0.0",
    "scheme": "todolist",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rameshv.todolist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.rameshv.todolist"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router"
    ]
  }
}
