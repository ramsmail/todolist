# Git worktrees live inside the repo but must never be uploaded to Vercel.
# They carry their own (stale) copies of apps/web — including a package.json
# that collides on the "@todolist/web" name — plus ~1.6 GB of node_modules.
.worktrees

# Build artifacts / local scratch — regenerated by the build, never deployed.
.next
**/.next
*.tsbuildinfo
.tmp-*
